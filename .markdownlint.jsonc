{
  // Default: all rules enabled
  "default": true,

  // Allow longer lines (documentation often has long lines)
  "MD013": false,

  // Allow inline HTML (useful for badges, etc.)
  "MD033": false,

  // Allow multiple headings with same content (different sections)
  "MD024": {
    "siblings_only": true
  },

  // Allow trailing punctuation in headings (for Russian text)
  "MD026": false
}
